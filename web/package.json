{
  "name": "tree-sitter-autohotkey-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Browser demo for the tree-sitter-autohotkey grammar",
  "scripts": {
    "build:wasm": "node scripts/build-grammar-wasm.mjs",
    "predev": "npm run build:wasm",
    "dev": "vite",
