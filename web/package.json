    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@uiw/react-codemirror": "^4.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "web-tree-sitter": "0.26.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^10.7.0",
    "prettier": "3.9.5",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.0.0"
  }
}
